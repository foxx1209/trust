---
import Layout from "@layouts/Layout.astro";
import SubFv from "@components/sub-fv.astro";
import CardCl from "@components/CardCl.astro";
import Close from "@components/Close.astro";
import CategoryTabs from "@components/CategoryTabs.astro";
import { getCollection } from "astro:content";
import { CATEGORIES, type CategoryKey } from "@src/categories";

export async function getStaticPaths() {
  const pageSize = 6;
  const allBlogs = await getCollection("blogs");
  const paths = [];

  for (const categoryKey of Object.keys(CATEGORIES)) {
    const filtered = allBlogs.filter(
      (blog) => blog.data.category?.includes(categoryKey as any)
    );

    const totalPages = Math.ceil(filtered.length / pageSize);

    for (let page = 2; page <= totalPages; page++) {
      const start = (page - 1) * pageSize;
      const end = start + pageSize;

      paths.push({
        params: {
          category: categoryKey,
          page: String(page),
        },
        props: {
          blogs: filtered.slice(start, end),
          totalPages,
          currentPage: page,
          categoryKey,
        },
      });
    }
  }

  return paths;
}

const { blogs, totalPages, currentPage, categoryKey } = Astro.props;
const category = CATEGORIES[categoryKey as CategoryKey];
---

<Layout
  title={`${category.name}の記事一覧 ${currentPage}ページ目 | Nexus Strategy`}
  description={category.description}
>
  <SubFv title={category.name} titleEn="Column" sp/>
  <div class="column" data-aos="fade-up" data-aos-duration="3000">
    <div class="column__inner">
      <CategoryTabs currentCategory={categoryKey} />
      
      <CardCl items={blogs} baseUrl="column" />
      
      {totalPages > 1 && (
        <div class="column__paganation">
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
            <a
              href={
                page === 1
                  ? `${import.meta.env.BASE_URL}column/${category.slug}/`
                  : `${import.meta.env.BASE_URL}column/${category.slug}/page/${page}/`
              }
              class={page === currentPage ? "column__paganation-link is-active" : "column__paganation-link"}
            >
              <span class="column__paganation-number">{page}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
  <Close />
</Layout>

<style>
  .column{
    padding-bottom: calc(80* var(--torem));
    background: url("../../../../assets/images/column-cards-bg.png") no-repeat top;
    background-size: cover;

    @media(width >= 48rem) {
      padding-bottom: calc(150* var(--torem));
      background-size: contain;
    }
  }
  .column__inner {
    padding: 0 calc(20* var(--torem));
  }

.column__paganation {
margin-block-start: calc(30* var(--torem));
display: flex;
flex-wrap: wrap;
justify-content: center;
max-inline-size: calc(250* var(--torem));
inline-size: 100%;
margin-inline: auto;
inline-size: fit-content;
gap: calc(10* var(--torem));
@media(width >= 48rem) {
  margin-block-start: calc(60* var(--torem));
}

}

.column__paganation-link {
text-decoration: none;
inline-size: calc(36* var(--torem));
block-size: calc(36* var(--torem));
border-radius: 50%;
display: grid;
place-items: center;
background-color: var(--white);
transition: all 0.3s ease;
position: relative;
}

.column__paganation-link::after{
  content: "";
  display: block;
  position: absolute;
  top: -1px;
  left: -1px;
  background: linear-gradient(135deg, #000000 0%, #2a2a2a 100%);
  border-radius: 50%;
  inline-size: calc(100% + 2px);
  block-size: calc(100% + 2px);
  background-color: var(--white);
  z-index: -1;
}
.column__paganation-number{
  font-size: calc(18* var(--torem));
  font-weight: 400;
  transition: all 0.3s ease;
background: linear-gradient(135deg, #000000 0%, #2a2a2a 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
text-fill-color: transparent;
position: relative;



}
.column__paganation-link.is-active{
  background: linear-gradient(135deg, #000000 0%, #2a2a2a 100%);
}
.column__paganation-link.is-active .column__paganation-number{
  color: var(--white);
background:initial;
  -webkit-background-clip: initial;
-webkit-text-fill-color: initial;
background-clip: initial;
text-fill-color: initial;
}
@media (any-hover: hover) {
.column__paganation-link:hover::after{
  opacity: 1;
}
.column__paganation-link:hover .column__paganation-number{
  opacity: 0.7;
}
}
</style>
