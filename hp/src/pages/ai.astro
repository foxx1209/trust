---
import SubFv from "@components/sub-fv.astro";
import Layout from "@layouts//Layout.astro";
import Section from "@components/SectionHeader.astro";
import CardContent from "@components/CardContent.astro";
import Close from "@components/Close.astro";

import {Image} from "astro:assets";
import Ai1 from "../assets/images/ai1.png";
import Ai2 from "../assets/images/ai2.png";
import Ai3 from "../assets/images/chat.png";
import Card7 from "../assets/images/section-card7.jpg";
import Card8 from "../assets/images/section-card8.jpg";
import Card9 from "../assets/images/section-card9.jpg";
import Card10 from "../assets/images/section-card10.jpg";
import Card11 from "../assets/images/section-card11.jpg";
import Card12 from "../assets/images/section-card12.jpg";
import Card13 from "../assets/images/section-card13.jpg";
import Card14 from "../assets/images/section-card14.jpg";
import Card15 from "../assets/images/section-card15.jpg";
import Card16 from "../assets/images/section-card16.jpg";



---

<Layout title="組織・デジタル変革支援 | Nexus Strategy"  description="DX推進から組織改革まで、企業の変革を包括的に支援します">
  <SubFv title="組織・デジタル<br>変革支援" titleEn="Transformation" sp/>

    <section class="section-wrapper" data-aos="fade-up" data-aos-duration="3000">
      <Section title="デジタルトランスフォーメーション（DX）戦略" img={Ai1} subTitle="最新技術を活用した<br>事業変革と競争優位性の確立" text="既存ビジネスモデルの変革からデジタル基盤の構築まで、包括的なDX推進を支援。現状分析から実行計画、変革推進まで一気通貫でサポートします。" alt="DX戦略コンサルティング" />
      <div class="section-cards">
        <CardContent number="01" img={Card7} title="DX現状診断・ロードマップ策定" text="既存の業務プロセス、IT環境、組織体制を包括的に分析。デジタル化の優先順位と投資対効果を明確にし、実行可能なロードマップを策定します。" alt="DX現状診断" first/>
        <CardContent number="02" img={Card8} title="デジタル基盤設計・構築" text="クラウド環境、データ基盤、システムアーキテクチャの最適化を設計。拡張性と安全性を両立した次世代IT基盤を構築します。" alt="デジタル基盤設計" second/>
        <CardContent number="03" img={Card9} title="ビジネスモデル変革支援" text="デジタル技術を活用した新規事業開発、既存事業の高度化を支援。市場分析から実証実験、事業化まで伴走します。" alt="ビジネスモデル変革" third/>
        <CardContent number="04" img={Card10} title="効果測定・継続的改善" text="KPI設定から定期的なモニタリング、改善提案まで実施。PDCAサイクルを回し、DX投資の効果を最大化します。" alt="効果測定・継続的改善" second/>
      </div>
    </section>
    <section class="section-wrapper" data-aos="fade-up" data-aos-duration="3000">
      <Section title="組織変革・<br>人材育成支援" sp img={Ai2} subTitle="変革を推進できる組織文化と<br>人材基盤の構築" text="組織構造の最適化から人材育成プログラムまで、変革を成功に導く組織づくりを支援。リーダーシップ開発、変革マネジメント、スキル育成を統合的に実施します。" alt="組織変革コンサルティング" />
      <div class="section-cards">
        <CardContent number="01" img={Card11} title="組織診断・変革設計" text="現状の組織構造、意思決定プロセス、企業文化を分析。変革の阻害要因を特定し、最適な組織モデルを設計します。" alt="組織診断" first/>
        <CardContent number="02" img={Card12} title="リーダーシップ開発" text="変革を推進するリーダー層の育成プログラムを提供。戦略思考、変革マネジメント、ピープルマネジメントのスキルを強化します。" alt="リーダーシップ開発" second/>
        <CardContent number="03" img={Card13} title="デジタル人材育成" text="全社員のデジタルリテラシー向上から、専門人材の育成まで実施。実践的なワークショップとOJTで定着を支援します。" alt="デジタル人材育成" third/>
      </div>
    </section>
    <section class="section-wrapper section-wrapper-last" data-aos="fade-up" data-aos-duration="3000">
      <Section title="業務プロセス改革・効率化" img={Ai3} subTitle="無駄を排除し、価値創造に集中できる<br>業務環境を実現" text="業務プロセスの可視化から再設計、自動化まで一貫して支援。コスト削減と生産性向上を同時に実現し、競争力を強化します。" alt="業務プロセス改革" />
      <div class="section-cards">
        <CardContent number="01" img={Card14} title="業務プロセス可視化・分析" text="現行業務を詳細に可視化し、ボトルネック、重複作業、非効率なプロセスを特定。改善ポテンシャルを定量的に評価します。" alt="プロセス可視化" first/>
        <CardContent number="02" img={Card15} title="プロセス再設計・標準化" text="ベストプラクティスに基づき、最適な業務フローを設計。標準化により品質の安定化と教育コストの削減を実現します。" alt="プロセス再設計" second/>
        <CardContent number="03" img={Card16} title="自動化・システム導入支援" text="RPA、ワークフローシステム等の導入により、定型業務を自動化。人的リソースを高付加価値業務にシフトします。" alt="業務自動化" third/>
      </div>
    </section>

  <Close />
</Layout>
<style>
  .u-sp{
    display: block;
    @media(width >= 48rem) {
      display: block;
    }
  }

.section-wrapper + .section-wrapper{
  margin-top: calc(80* var(--torem));
  @media(width >= 48rem) {
    margin-top: calc(150* var(--torem));
  }
}
.section-wrapper-last{
  margin-bottom: calc(80* var(--torem));
  @media(width >= 48rem) {
    margin-bottom: calc(150* var(--torem));
  }
}


  .section-cards{
  display: grid;
  background-color: var(--off-white);
  border-top-left-radius: 20px;
  border-bottom-left-radius: 20px;
  max-inline-size: calc(1320* var(--torem));
  inline-size: 100%;
  margin-left: auto;
  position: relative;
  z-index: 1;
  padding-inline-start: calc(15* var(--torem));
  padding-inline-end: calc(15* var(--torem));
  @media(width >= 48rem) {
      margin-block-start: calc(-153* var(--torem));
padding-inline-start: fluid(20px 103px);
  padding-inline-end: fluid(20px 100px);
  }
}
 
.card-content__text + span{
background: linear-gradient(135deg, #000000 0%, #2a2a2a 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
text-fill-color: transparent;
}
  
</style>
