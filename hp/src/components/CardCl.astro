---
import { Image } from 'astro:assets';
import Sample from "../assets/images/no-image.webp";
import Btn from "@components/Button.astro";

/**
 * 汎用的なカード一覧表示コンポーネント
 * 
 * 使用例:
 * - ブログ記事一覧: <CardCl items={blogs} baseUrl="column" />
 * - ダウンロード資料: <CardCl items={downloads} baseUrl="download" />
 * - ニュース一覧: <CardCl items={news} baseUrl="news" />
 */
// 型を定義
interface Props {
  items: any[];  // 表示するアイテムの配列（必須）
  baseUrl?: string;  // リンク先のベースURL（デフォルト: "column"）
}

const { 
  items, 
  baseUrl = ""  // デフォルトは "column"
} = Astro.props;


---

 <div class="column__cards">
  {
items.map((item) => (
 <a class="card" href={`${import.meta.env.BASE_URL}${baseUrl}/${item.id}`}>
  <div class="card__img"> 
    {
      item.data.img?
      <img width="100" height="100" loading="lazy" decoding="async" src={item.data.img?.url} alt={item.data.img?.alt || item.data.title}/>
      :
        <Image src={Sample} alt={item.data.title} />
    }
  </div>
    <h3 class="card__title">{item.data.title}</h3>
    
  
</a>  ))
}
</div>

<style>
  .column__cards { 
  display: grid;
  gap: calc(20* var(--torem));
  max-inline-size: calc(1140* var(--torem));
  margin-inline: auto;
  margin-block-start: calc(30* var(--torem));
  @media(width >= 48rem) {
    gap: fluid( 10px 40px);
  grid-template-columns: repeat(3,1fr);
  margin-block-start: calc(50* var(--torem));
  }
}

.column__btn {
display: grid;
place-items: center;
margin-top: calc(15* var(--torem));
@media(width >= 48rem) {
  margin-top: calc(45* var(--torem));
}
}
.card {
  display: grid;
  grid-row: span 3;
  grid-template-rows: subgrid;
  gap: 0;
  align-items: start;
  gap: calc(15* var(--torem));
  inline-size: 100%;
  margin-inline: auto;
max-inline-size: calc(400* var(--torem));
  background-color: var(--white);
  padding:calc(20* var(--torem));
  text-decoration: none;
    transition: all 0.3s ease-in-out;

  @media(width >= 48rem) {
      max-inline-size: calc(340* var(--torem));
      inline-size: 100%;
        padding:fluid( 10px 19px);
  }
}
@media (any-hover: hover) {

.card:hover {
  opacity: 0.8;
  transform: translateY(-10px);
  transition: transform 0.3s ease-in-out;
}
}

.card__img {
max-inline-size: calc(400* var(--torem));
inline-size: 100%;
margin-inline: auto;
img{
  aspect-ratio: 295/212;
  object-fit: cover;
  inline-size: 100%;
  block-size: 100%;
}
@media(width >= 48rem) {
  max-inline-size: calc(295* var(--torem));
}
}



.card__body-header {
display: flex;
align-items: center;
gap: calc(10* var(--torem));
}

.categry__name {
color: var(--white);
letter-spacing: 0.1em;
padding: calc(3* var(--torem)) calc(5* var(--torem));
font-size:calc(11* var(--torem));
background: linear-gradient(135deg, #000000 0%, #2a2a2a 100%);
font-weight: 700;
@media(width >= 48rem) {
  font-size: calc(14* var(--torem));
}

}

.card__date {
  font-size: calc(11* var(--torem));
  letter-spacing: 0.03em;
  flex-shrink: 0;
  @media(width >= 48rem) {
  font-size: calc(14* var(--torem));
  
}
}

.card__title {
font-size: calc(14* var(--torem));
font-weight: 500;
@media(width >= 48rem) {
  font-size: calc(16* var(--torem));
}
}


</style>
