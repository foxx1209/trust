---
// Config
import SubFv from "@components/sub-fv.astro";
// Layout
import Layout from "@layouts//Layout.astro";
import Section from "@components/SectionHeader.astro";
import CardContent from "@components/CardContent.astro";
import Close from "@components/Close.astro";

import {Image} from "astro:assets";
import Btob1 from "../assets/images/btob.png";
import hub from "../assets/images/hub.png";
import insaide from "../assets/images/insaide.png";
import Card1 from "../assets/images/section-card1.jpg";
import Card2 from "../assets/images/section-card2.jpg";
import Card3 from "../assets/images/section-card3.jpg";
import Card4 from "../assets/images/section-card4.jpg";
import Card5 from "../assets/images/section-card5.jpg";
import Card6 from "../assets/images/section-card6.jpg";

---

<Layout title="経営戦略コンサルティング | Nexus Strategy"  description="事業戦略から市場参入まで、企業成長を実現する戦略支援">
  <SubFv title="経営戦略<br>コンサルティング" titleEn="Strategy" sp/>

    <section class="section-wrapper" data-aos="fade-up" data-aos-duration="3000">
      <Section title="事業戦略立案・実行支援" img={Btob1} subTitle="持続的成長を実現する、<br>戦略的フレームワークの構築" text="市場分析から事業ポートフォリオの最適化まで、企業の持続的成長を支える戦略を立案。現場との密な連携により、実行可能性の高い戦略を策定し、成果創出まで伴走します。" alt="事業戦略立案" />
      <div class="section-cards">
        <CardContent number="01" img={Card1} title="市場分析・競合調査" text="詳細な<span>市場動向分析</span>と競合ベンチマーキングにより、事業機会を特定。業界構造、顧客ニーズ、技術トレンドを多角的に分析し、<span>戦略的方向性</span>を明確化します。定量・定性データを組み合わせた<span>精緻な分析</span>で、確実な意思決定を支援いたします。" alt="市場分析" first blue/>
        <CardContent number="02" img={Card2} title="事業ポートフォリオ最適化" text="既存事業の収益性評価と成長ポテンシャルの分析により、<span>最適な資源配分</span>を提案します。撤退・縮小・維持・拡大の判断基準を明確化し、企業価値の最大化を実現する<span>ポートフォリオ戦略</span>を策定いたします。" alt="ポートフォリオ最適化" second grade/>
        <CardContent number="03" img={Card3} title="実行計画策定・KPI設定" text="戦略を具体的なアクションプランに落とし込み、<span>実行可能なロードマップ</span>を作成。適切なKPIを設定し、進捗管理の仕組みを構築します。定期的なモニタリングと<span>柔軟な軌道修正</span>により、確実な成果創出を支援します。" alt="実行計画策定" third blue/>
      </div>
    </section>
    <section class="section-wrapper" data-aos="fade-up" data-aos-duration="3000">
      <Section title="市場参入戦略支援" img={hub} subTitle="新規市場への進出を、<br>リスクを最小化しながら成功に導く" text="新規市場参入の戦略立案から実行まで一貫支援。市場調査、参入方法の選定、ビジネスモデル設計、パートナーシップ構築を通じて、確実な市場浸透を実現します。" alt="市場参入戦略" />
      <div class="section-cards">
        <CardContent number="01" img={Card4} title="参入戦略立案・実行支援" text="市場魅力度評価、参入障壁分析、競争優位性の構築まで、包括的な参入戦略を策定。参入後の事業拡大を見据えた中長期計画を立案し、成功確率を最大化します。" alt="市場参入戦略立案" second/>
      </div>
    </section>
    <section class="section-wrapper section-wrapper-last">
      <Section title="M&A戦略支援" sp img={insaide} subTitle="企業価値を最大化する、<br>戦略的M&Aの立案と実行" text="M&A戦略の立案からターゲット企業の選定、デューデリジェンス、PMIまで包括的に支援。企業の成長戦略に合致した最適なM&Aを実現し、シナジー効果を最大化します。" alt="M&A戦略支援" />
      <div class="section-cards">
        <CardContent number="01" img={Card5} title="M&A戦略立案・ターゲット選定" text="成長戦略に基づくM&A方針を策定し、最適なターゲット企業をロングリスト・ショートリストで絞り込み。戦略的フィットと財務的魅力度の両面から評価します。" alt="M&A戦略立案" first/>
        <CardContent number="02" img={Card6} title="PMI（統合後マネジメント）支援" text="M&A後の統合プロセスを設計・実行し、シナジー効果を早期に実現。組織統合、システム統合、文化融合を段階的に推進し、統合リスクを最小化します。" alt="PMI支援" second/>
      </div>
    </section>
      <Close />
</Layout>
<style>
  .u-sp{
    display: block;
    @media(width >= 48rem) {
      display: block;
    }
  }

.section-wrapper + .section-wrapper{
  margin-top: calc(80* var(--torem));
  @media(width >= 48rem) {
    margin-top: calc(150* var(--torem));
  }
}
.section-wrapper-last{
  margin-bottom: calc(80* var(--torem));
  @media(width >= 48rem) {
    margin-bottom: calc(150* var(--torem));
  }
}


  .section-cards{
  display: grid;
  background-color: var(--off-white);
  border-top-left-radius: 20px;
  border-bottom-left-radius: 20px;
  max-inline-size: calc(1320* var(--torem));
  inline-size: 100%;
  margin-left: auto;
  position: relative;
  z-index: 1;
  padding-inline-start: calc(15* var(--torem));
  padding-inline-end: calc(15* var(--torem));
  @media(width >= 48rem) {
      margin-block-start: calc(-153* var(--torem));
padding-inline-start: fluid(30px 103px);
  padding-inline-end: fluid(20px 100px);
  }
}
 
.card-content__text + span{
background: linear-gradient(135deg, #000000 0%, #2a2a2a 100%);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
text-fill-color: transparent;
}
  
</style>